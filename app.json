{
  "expo": {
    "name": "Angel",
    "slug": "angel-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tlenoir.angelassistant",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Angel needs microphone access for voice messages.",
        "NSCameraUsageDescription": "Angel uses the camera so you can ask questions about what you see.",
        "UIBackgroundModes": [
          "audio",
          "remote-notification",
          "audio",
          "remote-notification"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "RECORD_AUDIO",
        "CAMERA",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.CAMERA"
      ]
    },
    "plugins": [
      [
        "expo-audio",
        {
          "microphonePermission": "Angel needs microphone access for voice messages."
        }
      ],
      [
        "expo-notifications",
        {
          "sounds": []
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Angel can attach photos when you choose from the library.",
          "cameraPermission": "Angel uses the camera so you can ask questions about what you see."
        }
      ],
      "expo-dev-client"
    ],
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "0d3aa980-c7a5-40a1-b507-5898aec297da"
      }
    }
  }
}
